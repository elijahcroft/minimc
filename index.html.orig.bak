<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Mini Minecraft</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; overflow: hidden; background: #9fd4ff; font-family: monospace; color: #fff; }
  canvas { display: block; }

  #crosshair {
    position: fixed; top: 50%; left: 50%; width: 20px; height: 20px;
    transform: translate(-50%, -50%); pointer-events: none; z-index: 10;
  }
  #crosshair::before, #crosshair::after { content: ""; position: absolute; background: rgba(255,255,255,0.85); }
  #crosshair::before { left: 9px; top: 0; width: 2px; height: 20px; }
  #crosshair::after { top: 9px; left: 0; height: 2px; width: 20px; }

  #hud { position: fixed; bottom: 14px; left: 50%; transform: translateX(-50%); display: flex; gap: 5px; z-index: 10; }
  .slot {
    width: 50px; height: 50px; border: 3px solid rgba(0,0,0,0.4);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    font-size: 10px; text-align: center; line-height: 1.15; text-shadow: 1px 1px 1px #000; position: relative;
  }
  .slot .num { position: absolute; top: 1px; left: 3px; font-size: 9px; opacity: 0.85; }
  .slot.active { border-color: #fff; box-shadow: 0 0 0 1px #000; }

  #hearts {
    position: fixed; bottom: 72px; left: 50%; transform: translateX(-50%); z-index: 10;
    font-size: 22px; letter-spacing: 3px; display: none; text-shadow: 1px 1px 2px #000;
  }

  #info {
    position: fixed; top: 12px; left: 12px; z-index: 10; font-size: 12px; line-height: 1.5;
    background: rgba(0,0,0,0.4); padding: 5px 9px; border-radius: 3px; white-space: pre;
  }

  #hurt {
    position: fixed; inset: 0; z-index: 9; pointer-events: none; opacity: 0;
    background: radial-gradient(circle, rgba(150,0,0,0) 35%, rgba(150,0,0,0.65) 100%);
  }
  #prompt {
    position: fixed; bottom: 110px; left: 50%; transform: translateX(-50%); z-index: 10;
    font-size: 14px; background: rgba(0,0,0,0.55); padding: 6px 12px; border-radius: 4px; display: none;
  }

  #overlay, #menu, #death {
    position: fixed; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center; background: rgba(0,0,0,0.6); text-align: center;
  }
  #overlay, #menu { z-index: 20; }
  #death { z-index: 25; background: rgba(60,0,0,0.6); }
  #death h1 { font-size: 46px; color: #d33; letter-spacing: 3px; }
  #death p { margin-top: 10px; opacity: 0.85; }
  #overlay { cursor: pointer; }
  #overlay h1 { font-size: 34px; margin-bottom: 16px; letter-spacing: 3px; }
  #overlay p { font-size: 13px; line-height: 1.9; opacity: 0.9; }
  .hidden { display: none !important; }

  #menu h2 { font-size: 22px; margin-bottom: 14px; letter-spacing: 2px; }
  #menuGrid { display: grid; grid-template-columns: repeat(8, 56px); gap: 8px; }
  .tile {
    width: 56px; height: 56px; border: 2px solid rgba(255,255,255,0.25); cursor: pointer;
    display: flex; align-items: flex-end; justify-content: center; padding-bottom: 3px;
    font-size: 9px; text-shadow: 1px 1px 1px #000;
  }
  .tile:hover { border-color: #fff; }
  #menu .hint { margin-top: 14px; font-size: 12px; opacity: 0.8; }
</style>
</head>
<body>
<div id="crosshair"></div>
<div id="hud"></div>
<div id="hearts"></div>
<div id="info"></div>
<div id="prompt"></div>
<div id="hurt"></div>

<div id="overlay">
  <h1>MINI MINECRAFT</h1>
  <p>
    Click to play<br><br>
    WASD — move &nbsp;·&nbsp; Mouse <b>or</b> Arrow keys — look (works while moving)<br>
    Space — jump &nbsp;·&nbsp; F — fly (creative only) &nbsp;·&nbsp; G — toggle Creative / Survival<br>
    Left click — break / attack &nbsp;·&nbsp; Right click — place &nbsp;·&nbsp; 1–9 / scroll — hotbar &nbsp;·&nbsp; E — menu<br>
    Survival: mobs fight back, you have health & take fall damage<br>
    R — board the 🚀 rocket near spawn, then fly up to the moon! &nbsp;·&nbsp; Esc — release mouse
  </p>
</div>

<div id="menu" class="hidden">
  <h2>CREATIVE INVENTORY</h2>
  <div id="menuGrid"></div>
  <div class="hint">Click an item to put it in your hand · E or Esc to close</div>
</div>

<div id="death" class="hidden"><h1>YOU DIED</h1><p>respawning…</p></div>

<script type="importmap">
{ "imports": { "three": "https://unpkg.com/three@0.160.0/build/three.module.js" } }
</script>

<script type="module">
import * as THREE from 'three';
import { PointerLockControls } from 'https://unpkg.com/three@0.160.0/examples/jsm/controls/PointerLockControls.js';

const TAU = Math.PI * 2;

// ============================================================ scene
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x9fd4ff);
scene.fog = new THREE.Fog(0x9fd4ff, 60, 140);

const camera = new THREE.PerspectiveCamera(75, innerWidth / innerHeight, 0.1, 1000);
const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(innerWidth, innerHeight);
renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
renderer.autoClear = false;
document.body.appendChild(renderer.domElement);

scene.add(new THREE.HemisphereLight(0xffffff, 0x556633, 0.85));
const sun = new THREE.DirectionalLight(0xffffff, 0.8);
sun.position.set(50, 100, 30);
scene.add(sun);

// ---- sky, moon, stars (space ambience kicks in as you climb) ----
const skyDay = new THREE.Color(0x9fd4ff);
const skySpace = new THREE.Color(0x05060f);
let gEff = 28;                         // effective gravity (drops with altitude → moon feel)

// Worlds you can fly the rocket to. Each has a sphere in the sky + a landing
// platform of blocks at platY/(px,pz) you can walk on, with aliens waiting.
const PLANETS = [
  { name: 'Moon',    color: 0xb9b9c6, emissive: 0x33343f, r: 64, pos: [0, 210, 0],     plat: 'moonrock', platR: 12, px: 0,    pz: 0,    platY: 100, aliens: 3 },
  { name: 'Mars',    color: 0xc1502e, emissive: 0x3a1206, r: 42, pos: [180, 160, 70],  plat: 'brick',    platR: 11, px: 180,  pz: 70,   platY: 120, aliens: 4 },
  { name: 'Frost',   color: 0x9fd0e6, emissive: 0x16323e, r: 48, pos: [-180, 185, -80],plat: 'snow',     platR: 11, px: -180, pz: -80,  platY: 140, aliens: 3 },
  { name: 'Inferno', color: 0xd9742a, emissive: 0x4a1500, r: 40, pos: [90, 240, -190], plat: 'obsidian', platR: 10, px: 90,   pz: -190, platY: 185, aliens: 4 },
  { name: 'Verdis',  color: 0x4caa5a, emissive: 0x123010, r: 54, pos: [-100, 150, 190],plat: 'grass',    platR: 12, px: -100, pz: 190,  platY: 115, aliens: 3 },
];
for (const pl of PLANETS) {
  const g = new THREE.SphereGeometry(pl.r, 30, 30);
  const pos = g.attributes.position;                 // jitter for cratered look
  for (let i = 0; i < pos.count; i++) {
    const f = 1 + (Math.random() - 0.5) * 0.06;
    pos.setXYZ(i, pos.getX(i) * f, pos.getY(i) * f, pos.getZ(i) * f);
  }
  g.computeVertexNormals();
  const m = new THREE.Mesh(g, new THREE.MeshStandardMaterial({ color: pl.color, emissive: pl.emissive, roughness: 1, fog: false }));
  m.position.set(...pl.pos);
  pl.mesh = m;
  scene.add(m);
}

const stars = (() => {
  const n = 1400, arr = new Float32Array(n * 3);
  for (let i = 0; i < n; i++) {
    const u = Math.random() * 2 - 1, th = Math.random() * Math.PI * 2, r = 380, s = Math.sqrt(1 - u * u);
    arr[i * 3] = r * s * Math.cos(th); arr[i * 3 + 1] = Math.abs(u) * r + 30; arr[i * 3 + 2] = r * s * Math.sin(th);
  }
  const g = new THREE.BufferGeometry();
  g.setAttribute('position', new THREE.BufferAttribute(arr, 3));
  const p = new THREE.Points(g, new THREE.PointsMaterial({ color: 0xffffff, size: 1.4, sizeAttenuation: false, transparent: true, opacity: 0, fog: false }));
  p.frustumCulled = false;
  return p;
})();
scene.add(stars);

// ============================================================ block + item types
const BLOCKS = {
  grass:       { name: 'Grass',   color: 0x5fb84e, pattern: 'grass' },
  dirt:        { name: 'Dirt',    color: 0x8a5a3b, pattern: 'dirt' },
  stone:       { name: 'Stone',   color: 0x8d8d8d, pattern: 'stone' },
  cobblestone: { name: 'Cobble',  color: 0x6f6f6f, pattern: 'cobble' },
  sand:        { name: 'Sand',    color: 0xe6d9a3, pattern: 'sand' },
  gravel:      { name: 'Gravel',  color: 0x9a948c, pattern: 'gravel' },
  log:         { name: 'Log',     color: 0x6b4a2b, pattern: 'log' },
  planks:      { name: 'Planks',  color: 0xb5894e, pattern: 'planks' },
  leaves:      { name: 'Leaves',  color: 0x46a23a, alpha: 0.92, pattern: 'leaves' },
  glass:       { name: 'Glass',   color: 0xcfe8ff, alpha: 0.35, pattern: 'glass' },
  brick:       { name: 'Brick',   color: 0xa83b2a, pattern: 'brick' },
  snow:        { name: 'Snow',    color: 0xffffff, pattern: 'snow' },
  water:       { name: 'Water',   color: 0x3a72d6, alpha: 0.6, pattern: 'water' },
  bedrock:     { name: 'Bedrock', color: 0x2b2b2b, pattern: 'bedrock' },
  gold:        { name: 'Gold',    color: 0xf2c530, pattern: 'gold' },
  obsidian:    { name: 'Obsidian',color: 0x2c2140, pattern: 'obsidian' },
  moonrock:    { name: 'Moonrock',color: 0xc8c8d0, pattern: 'moonrock' },
};
const TYPES = Object.keys(BLOCKS);
const TOOLS = {
  sword: { name: 'Sword', color: 0xb9c4cc },
  bow:   { name: 'Bow',   color: 0x9a6b32 },
  gun:   { name: 'Gun',   color: 0x33373c },
};
const isBlock  = (id) => id in BLOCKS;
const isOpaque = (t)  => t != null && isBlock(t) && BLOCKS[t].alpha == null;
const isSolid  = (t)  => t != null && isBlock(t) && t !== 'water';
const swatch   = (id) => '#' + (BLOCKS[id] || TOOLS[id]).color.toString(16).padStart(6, '0');
const itemName = (id) => (BLOCKS[id] || TOOLS[id]).name;

function makeTexture(hex, pattern) {
  const s = 16, c = document.createElement('canvas');
  c.width = c.height = s;
  const ctx = c.getContext('2d');
  const col = new THREE.Color(hex);
  const rnd = Math.random;
  for (let y = 0; y < s; y++) for (let x = 0; x < s; x++) {
    let l = 1 + (rnd() - 0.5) * 0.18;
    switch (pattern) {
      case 'planks':
        if (y % 5 === 0) l *= 0.7;          // plank seams
        else if (x === 7) l *= 0.82;        // centre joint
        break;
      case 'log':
        if (x === 0 || x === s - 1) l *= 0.6;     // dark bark edges
        else if (x % 4 === 1) l *= 0.84;          // vertical grain
        break;
      case 'brick': {
        const off = (Math.floor(y / 4) % 2) ? 4 : 0;
        if (y % 4 === 0 || (x + off) % 8 === 0) l *= 0.55;
        break;
      }
      case 'grass':
        l = 1 + (rnd() - 0.5) * 0.12;
        if (rnd() > 0.9) l *= 1.18;         // bright blades
        else if (rnd() > 0.9) l *= 0.82;
        break;
      case 'dirt':
        l = 1 + (rnd() - 0.5) * 0.2;
        if (rnd() > 0.92) l *= 0.76;        // dark clumps
        break;
      case 'stone':
        l = 1 + (rnd() - 0.5) * 0.1;
        if (rnd() > 0.95) l *= 0.7;         // dark flecks
        break;
      case 'cobble':
        l = 1 + (rnd() - 0.5) * 0.22;
        if (x % 8 === 0 || y % 8 === 0 || (x + y) % 16 === 0) l *= 0.5;  // mortar grid
        break;
      case 'sand':
        l = 1 + (rnd() - 0.5) * 0.1;
        if (rnd() > 0.88) l *= 1.08;        // glinting grains
        break;
      case 'gravel': {
        const cell = (Math.floor(x / 2) * 31 + Math.floor(y / 2) * 17) % 5;
        l = 0.82 + cell * 0.09 + (rnd() - 0.5) * 0.12;   // pebbles
        break;
      }
      case 'leaves': {
        const cell = (Math.floor(x / 3) * 13 + Math.floor(y / 3) * 7) % 4;
        l = 0.82 + cell * 0.09 + (rnd() - 0.5) * 0.18;   // clumps
        break;
      }
      case 'glass':
        l = 1 + (rnd() - 0.5) * 0.04;
        if (x === 0 || y === 0 || x === s - 1 || y === s - 1) l *= 0.7;  // frame
        else if (x === y || x === y - 1) l *= 1.3;                       // shine
        break;
      case 'snow':
        l = 1 + (rnd() - 0.5) * 0.06;
        if (rnd() > 0.95) l *= 0.92;
        break;
      case 'water':
        l = 1 + Math.sin((y + x * 0.3) * 0.9) * 0.06 + (rnd() - 0.5) * 0.05;  // ripples
        break;
      case 'bedrock': {
        const cell = (Math.floor(x / 2) * 23 + Math.floor(y / 2) * 41) % 6;
        l = 0.6 + cell * 0.13;              // jagged blocks
        break;
      }
      case 'gold':
        l = 1 + (rnd() - 0.5) * 0.12;
        if (rnd() > 0.9) l *= 1.35;         // sparkle
        break;
      case 'obsidian':
        l = 1 + (rnd() - 0.5) * 0.25;
        if (rnd() > 0.93) l *= 1.6;         // purple glints
        break;
      case 'moonrock':
        l = 1 + (rnd() - 0.5) * 0.1;
        if (rnd() > 0.95) l *= 1.2;
        else if (rnd() > 0.92) l *= 0.62;   // craters
        break;
    }
    const r = Math.min(255, col.r * 255 * l) | 0;
    const g = Math.min(255, col.g * 255 * l) | 0;
    const b = Math.min(255, col.b * 255 * l) | 0;
    ctx.fillStyle = `rgb(${r},${g},${b})`;
    ctx.fillRect(x, y, 1, 1);
  }
  const t = new THREE.CanvasTexture(c);
  t.magFilter = THREE.NearestFilter; t.minFilter = THREE.NearestFilter;
  return t;
}
function makeMaterial(type) {
  const b = BLOCKS[type];
  const m = new THREE.MeshLambertMaterial({ map: makeTexture(b.color, b.pattern) });
  if (b.alpha != null) { m.transparent = true; m.opacity = b.alpha; }
  return m;
}

// ============================================================ instanced world rendering
const geometry = new THREE.BoxGeometry(1, 1, 1);
const CAPACITY = 16000;
const ZERO = new THREE.Matrix4().makeScale(0, 0, 0);
const dummy = new THREE.Object3D();

const meshes = {};
const meshArr = [];
for (const t of TYPES) {
  const mesh = new THREE.InstancedMesh(geometry, makeMaterial(t), CAPACITY);
  mesh.frustumCulled = false;
  mesh.count = 0;
  scene.add(mesh);
  meshes[t] = { mesh, free: [], next: 0, idToCoord: new Map() };
  meshArr.push(mesh);
}

const world = new Map();
const key = (x, y, z) => x + ',' + y + ',' + z;
const rendered = new Map();
const pops = [];

function shouldRender(x, y, z, type) {
  if (!isOpaque(type)) return true;
  return !(isOpaque(world.get(key(x + 1, y, z))) && isOpaque(world.get(key(x - 1, y, z))) &&
           isOpaque(world.get(key(x, y + 1, z))) && isOpaque(world.get(key(x, y - 1, z))) &&
           isOpaque(world.get(key(x, y, z + 1))) && isOpaque(world.get(key(x, y, z - 1))));
}
function instMatrix(x, y, z, s) {
  dummy.position.set(x + 0.5, y + 0.5, z + 0.5);
  dummy.scale.set(s, s, s);
  dummy.updateMatrix();
  return dummy.matrix;
}
function setInstance(k, x, y, z, type) {
  const bm = meshes[type];
  let id = bm.free.length ? bm.free.pop() : bm.next++;
  if (id >= CAPACITY) { bm.next = CAPACITY; return; }
  if (id + 1 > bm.mesh.count) bm.mesh.count = id + 1;
  bm.mesh.setMatrixAt(id, instMatrix(x, y, z, 1));
  bm.mesh.instanceMatrix.needsUpdate = true;
  bm.idToCoord.set(id, { x, y, z });
  rendered.set(k, [type, id]);
}
function clearInstance(k) {
  const r = rendered.get(k);
  if (!r) return;
  const bm = meshes[r[0]];
  bm.mesh.setMatrixAt(r[1], ZERO);
  bm.mesh.instanceMatrix.needsUpdate = true;
  bm.idToCoord.delete(r[1]);
  bm.free.push(r[1]);
  rendered.delete(k);
}
function ensureRender(x, y, z) {
  const k = key(x, y, z);
  const type = world.get(k);
  const want = type != null && shouldRender(x, y, z, type);
  const cur = rendered.get(k);
  if (!want) { if (cur) clearInstance(k); return; }
  if (cur) { if (cur[0] !== type) { clearInstance(k); setInstance(k, x, y, z, type); } }
  else setInstance(k, x, y, z, type);
}
function refreshAround(x, y, z) {
  ensureRender(x, y, z);
  ensureRender(x + 1, y, z); ensureRender(x - 1, y, z);
  ensureRender(x, y + 1, z); ensureRender(x, y - 1, z);
  ensureRender(x, y, z + 1); ensureRender(x, y, z - 1);
}

// ============================================================ terrain generation
function rand(x, z) { const s = Math.sin(x * 127.1 + z * 311.7) * 43758.5453; return s - Math.floor(s); }
function smooth2(x, z) {
  const xi = Math.floor(x), zi = Math.floor(z), xf = x - xi, zf = z - zi;
  const u = xf * xf * (3 - 2 * xf), v = zf * zf * (3 - 2 * zf);
  const a = rand(xi, zi), b = rand(xi + 1, zi), c = rand(xi, zi + 1), d = rand(xi + 1, zi + 1);
  return a + (b - a) * u + (c - a) * v + (a - b - c + d) * u * v;
}
function rand3(x, y, z) { const s = Math.sin(x * 12.9 + y * 78.2 + z * 37.7) * 43758.5; return s - Math.floor(s); }
function smooth3(x, y, z) {
  const xi = Math.floor(x), yi = Math.floor(y), zi = Math.floor(z);
  const xf = x - xi, yf = y - yi, zf = z - zi;
  const u = xf * xf * (3 - 2 * xf), v = yf * yf * (3 - 2 * yf), w = zf * zf * (3 - 2 * zf);
  const L = (a, b, t) => a + (b - a) * t;
  return L(
    L(L(rand3(xi, yi, zi), rand3(xi + 1, yi, zi), u), L(rand3(xi, yi + 1, zi), rand3(xi + 1, yi + 1, zi), u), v),
    L(L(rand3(xi, yi, zi + 1), rand3(xi + 1, yi, zi + 1), u), L(rand3(xi, yi + 1, zi + 1), rand3(xi + 1, yi + 1, zi + 1), u), v), w);
}

const SIZE = 40, SEA = 7;
function heightAt(x, z) {
  const n = smooth2(x / 22, z / 22) * 1.0 + smooth2(x / 9, z / 9) * 0.35;
  return Math.floor(6 + n / 1.35 * 16);
}
function surfaceY(x, z) { return heightAt(x, z) + 1; }

for (let x = -SIZE; x <= SIZE; x++) {
  for (let z = -SIZE; z <= SIZE; z++) {
    const h = heightAt(x, z);
    let top = 'grass';
    if (h >= 20) top = 'snow'; else if (h <= SEA) top = 'sand';
    for (let y = 0; y <= h; y++) {
      if (y >= 2 && y <= h - 2 && smooth3(x / 9, y / 7, z / 9) > 0.78) continue;
      let type;
      if (y === 0) type = 'bedrock';
      else if (y === h) type = top;
      else if (y >= h - 3) type = (top === 'sand') ? 'sand' : 'dirt';
      else type = 'stone';
      world.set(key(x, y, z), type);
    }
    if (h < SEA) for (let y = h + 1; y <= SEA; y++) world.set(key(x, y, z), 'water');
  }
}
for (let x = -SIZE + 2; x <= SIZE - 2; x++) {
  for (let z = -SIZE + 2; z <= SIZE - 2; z++) {
    const h = heightAt(x, z);
    if (h <= SEA || h >= 20) continue;
    if (rand(x * 7.3, z * 3.1) > 0.985 && world.get(key(x, h, z)) === 'grass') {
      const th = 4 + Math.floor(rand(x, z) * 3);
      for (let i = 1; i <= th; i++) world.set(key(x, h + i, z), 'log');
      const ty = h + th;
      for (let dx = -2; dx <= 2; dx++) for (let dz = -2; dz <= 2; dz++) for (let dy = -1; dy <= 1; dy++) {
        if (Math.abs(dx) === 2 && Math.abs(dz) === 2) continue;
        const k = key(x + dx, ty + dy, z + dz);
        if (!world.has(k)) world.set(k, 'leaves');
      }
      world.set(key(x, ty + 1, z), 'leaves');
    }
  }
}
// landing platforms below each planet (walkable, with scattered rocks)
for (const pl of PLANETS) {
  for (let x = -pl.platR; x <= pl.platR; x++)
    for (let z = -pl.platR; z <= pl.platR; z++)
      if (x * x + z * z <= pl.platR * pl.platR) {
        world.set(key(pl.px + x, pl.platY, pl.pz + z), pl.plat);
        if (rand((pl.px + x) * 3.1, (pl.pz + z) * 5.7) > 0.93) world.set(key(pl.px + x, pl.platY + 1, pl.pz + z), pl.plat);
      }
}

for (const k of world.keys()) { const [x, y, z] = k.split(','); ensureRender(+x, +y, +z); }

// ============================================================ block highlight + voxel ray-march
const highlight = new THREE.LineSegments(
  new THREE.EdgesGeometry(new THREE.BoxGeometry(1.002, 1.002, 1.002)),
  new THREE.LineBasicMaterial({ color: 0x000000, transparent: true, opacity: 0.45 }));
highlight.visible = false;
scene.add(highlight);

function rayBlock(origin, dir, maxDist) {
  let ix = Math.floor(origin.x), iy = Math.floor(origin.y), iz = Math.floor(origin.z);
  const sx = Math.sign(dir.x), sy = Math.sign(dir.y), sz = Math.sign(dir.z);
  const tdx = sx !== 0 ? Math.abs(1 / dir.x) : Infinity;
  const tdy = sy !== 0 ? Math.abs(1 / dir.y) : Infinity;
  const tdz = sz !== 0 ? Math.abs(1 / dir.z) : Infinity;
  let tmx = sx > 0 ? (ix + 1 - origin.x) * tdx : (origin.x - ix) * tdx;
  let tmy = sy > 0 ? (iy + 1 - origin.y) * tdy : (origin.y - iy) * tdy;
  let tmz = sz > 0 ? (iz + 1 - origin.z) * tdz : (origin.z - iz) * tdz;
  if (sx === 0) tmx = Infinity; if (sy === 0) tmy = Infinity; if (sz === 0) tmz = Infinity;
  let nx = 0, ny = 0, nz = 0, t = 0;
  for (let i = 0; i < 64; i++) {
    if (world.has(key(ix, iy, iz))) return { x: ix, y: iy, z: iz, nx, ny, nz };
    if (tmx < tmy && tmx < tmz) { ix += sx; t = tmx; tmx += tdx; nx = -sx; ny = 0; nz = 0; }
    else if (tmy < tmz)         { iy += sy; t = tmy; tmy += tdy; nx = 0; ny = -sy; nz = 0; }
    else                        { iz += sz; t = tmz; tmz += tdz; nx = 0; ny = 0; nz = -sz; }
    if (t > maxDist) return null;
  }
  return null;
}
let aimBlock = null;
function updateAim() {
  const dir = new THREE.Vector3();
  camera.getWorldDirection(dir);
  aimBlock = rayBlock(controls.getObject().position, dir, 7);
  if (aimBlock) { highlight.visible = true; highlight.position.set(aimBlock.x + 0.5, aimBlock.y + 0.5, aimBlock.z + 0.5); }
  else highlight.visible = false;
}

// ============================================================ particles
const pGeo = new THREE.BoxGeometry(0.14, 0.14, 0.14);
const pMatCache = new Map();
const particles = [];
function colorMat(hex) {
  if (!pMatCache.has(hex)) pMatCache.set(hex, new THREE.MeshLambertMaterial({ color: hex }));
  return pMatCache.get(hex);
}
function spawnParticles(cx, cy, cz, hex, n) {
  if (particles.length > 220) return;
  for (let i = 0; i < n; i++) {
    const m = new THREE.Mesh(pGeo, colorMat(hex));
    m.position.set(cx + Math.random(), cy + Math.random(), cz + Math.random());
    scene.add(m);
    particles.push({ m, vx: (Math.random() - 0.5) * 4, vy: 3 + Math.random() * 3, vz: (Math.random() - 0.5) * 4, life: 0.6 + Math.random() * 0.3 });
  }
}
function updateParticles(dt) {
  for (let i = particles.length - 1; i >= 0; i--) {
    const p = particles[i];
    p.vy -= 18 * dt;
    p.m.position.x += p.vx * dt; p.m.position.y += p.vy * dt; p.m.position.z += p.vz * dt;
    p.life -= dt;
    const s = Math.max(0.01, p.life * 1.6);
    p.m.scale.set(s, s, s);
    if (p.life <= 0) { scene.remove(p.m); particles.splice(i, 1); }
  }
}

// ============================================================ controls & player
const controls = new PointerLockControls(camera, renderer.domElement);
scene.add(controls.getObject());

const RADIUS = 0.3, PLAYER_H = 1.7;
const GRAVITY = 28, WALK = 6, FLY = 13, JUMP = 9;
const MAX_HP = 20;
const SPAWN = new THREE.Vector3(0.5, surfaceY(0, 0) + PLAYER_H, 0.5);
controls.getObject().position.copy(SPAWN);

let gameMode = 'creative';
let flying = false;
let health = MAX_HP, dead = false, deathTimer = 0;
let hurtFlash = 0, lastHurt = -99, regenTimer = 0, clock = 0;
let airMaxY = SPAWN.y, wasGrounded = true;
const velocity = new THREE.Vector3();
let onGround = false;

const overlay = document.getElementById('overlay');
const menu = document.getElementById('menu');
const info = document.getElementById('info');
const hurtEl = document.getElementById('hurt');
const promptEl = document.getElementById('prompt');
const heartsEl = document.getElementById('hearts');
const deathEl = document.getElementById('death');
let menuOpen = false;

overlay.addEventListener('click', () => controls.lock());
controls.addEventListener('lock', () => overlay.classList.add('hidden'));
controls.addEventListener('unlock', () => { if (!menuOpen && !dead) overlay.classList.remove('hidden'); });

const keys = {};
addEventListener('keyup', (e) => keys[e.code] = false);
addEventListener('keydown', (e) => {
  keys[e.code] = true;
  if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'Space'].includes(e.code)) e.preventDefault();
  if (e.code === 'KeyE') { e.preventDefault(); toggleMenu(); return; }
  if (e.code === 'Escape' && menuOpen) { closeMenu(); return; }
  if (e.code === 'KeyF' && gameMode === 'creative') { flying = !flying; velocity.y = 0; }
  if (e.code === 'KeyG') setMode(gameMode === 'creative' ? 'survival' : 'creative');
  if (e.code === 'KeyR') toggleRocket();
  if (e.code.startsWith('Digit')) { const n = +e.code.slice(5) - 1; if (n >= 0 && n < 9) selectSlot(n); }
});

function setMode(m) {
  gameMode = m;
  if (m === 'survival') { flying = false; health = MAX_HP; heartsEl.style.display = 'block'; updateHearts(); }
  else { heartsEl.style.display = 'none'; hurtFlash = 0; hurtEl.style.opacity = 0; }
}

function collideBox(px, py, pz, r, h) {
  for (let x = Math.floor(px - r); x <= Math.floor(px + r); x++)
    for (let z = Math.floor(pz - r); z <= Math.floor(pz + r); z++)
      for (let y = Math.floor(py); y <= Math.floor(py + h); y++)
        if (isSolid(world.get(key(x, y, z)))) return true;
  return false;
}
function moveAxis(axis, amount, pos) {
  if (amount === 0) return;
  pos[axis] += amount;
  if (collideBox(pos.x, pos.y - PLAYER_H, pos.z, RADIUS, PLAYER_H)) {
    pos[axis] -= amount;
    if (axis === 'y') { if (amount < 0) onGround = true; velocity.y = 0; }
  }
}
function grounded(pos) { return collideBox(pos.x, pos.y - PLAYER_H - 0.05, pos.z, RADIUS, PLAYER_H); }

// arrow-key look (works simultaneously with WASD movement and the mouse)
const lookEuler = new THREE.Euler(0, 0, 0, 'YXZ');
function arrowLook(dt) {
  const r = 2.2 * dt;
  let turn = 0, pitch = 0;
  if (keys['ArrowLeft']) turn += r;
  if (keys['ArrowRight']) turn -= r;
  if (keys['ArrowUp']) pitch += r;
  if (keys['ArrowDown']) pitch -= r;
  if (turn === 0 && pitch === 0) return;
  lookEuler.setFromQuaternion(camera.quaternion);
  lookEuler.y += turn;
  lookEuler.x = Math.max(-1.5, Math.min(1.5, lookEuler.x + pitch));
  camera.quaternion.setFromEuler(lookEuler);
}

// ---- player damage / death ----
function updateHearts() {
  let s = '';
  for (let i = 0; i < 10; i++) {
    const v = health - i * 2;
    const col = v >= 2 ? '#e23344' : v === 1 ? '#ff8aa0' : '#555';
    s += `<span style="color:${col}">♥</span>`;
  }
  heartsEl.innerHTML = s;
}
function damagePlayer(dmg) {
  if (gameMode !== 'survival' || dead) return;
  health -= dmg; lastHurt = clock; hurtFlash = 0.55; updateHearts();
  if (health <= 0) die();
}
function hurtByMob(dmg, fromPos) {
  if (gameMode !== 'survival' || dead) return;
  const pos = controls.getObject().position;
  let kx = pos.x - fromPos.x, kz = pos.z - fromPos.z;
  const l = Math.hypot(kx, kz) || 1;
  pos.x += kx / l * 0.45; pos.z += kz / l * 0.45;
  velocity.y = 5;
  damagePlayer(dmg);
}
function die() {
  dead = true; deathTimer = 2; health = 0; updateHearts();
  deathEl.classList.remove('hidden');
  hurtFlash = 0.8;
}
function respawn() {
  dead = false; deathEl.classList.add('hidden');
  health = MAX_HP; updateHearts();
  controls.getObject().position.copy(SPAWN);
  velocity.set(0, 0, 0); airMaxY = SPAWN.y; wasGrounded = true;
}

// ============================================================ rocket
let piloting = false, flame;
const ROCKET_SPEED = 22;
const rocket = new THREE.Group();
(function buildRocket() {
  const cyl = (rt, rb, h, color, y) => {
    const m = new THREE.Mesh(new THREE.CylinderGeometry(rt, rb, h, 16), new THREE.MeshLambertMaterial({ color }));
    m.position.y = y; return m;
  };
  rocket.add(cyl(0.55, 0.55, 2.6, 0xeef1f6, 1.7));      // body
  rocket.add(cyl(0.0, 0.55, 1.1, 0xd23b32, 3.55));      // nose cone
  rocket.add(box(0.05, 0.45, 0.45, 0x2a3550, 0, 2.2, 0.55));   // window
  for (let i = 0; i < 4; i++) {                          // fins
    const fin = box(0.12, 0.7, 0.5, 0xd23b32, 0, 0.6, 0);
    fin.position.x = Math.cos(i * Math.PI / 2) * 0.6;
    fin.position.z = Math.sin(i * Math.PI / 2) * 0.6;
    fin.rotation.y = -i * Math.PI / 2;
    rocket.add(fin);
  }
  flame = new THREE.Mesh(new THREE.ConeGeometry(0.4, 1.3, 12), new THREE.MeshBasicMaterial({ color: 0xffae33 }));
  flame.rotation.x = Math.PI; flame.position.y = -0.3; flame.visible = false;
  rocket.add(flame);
})();
rocket.position.set(6.5, surfaceY(6, 2), 2.5);
scene.add(rocket);

const rocketDist = () => controls.getObject().position.distanceTo(rocket.position);
function toggleRocket() {
  if (piloting) {
    piloting = false; vmHand.visible = true; flame.visible = false;
    const p = controls.getObject().position;
    p.set(rocket.position.x + 1.6, rocket.position.y + PLAYER_H, rocket.position.z);
    velocity.set(0, 0, 0); wasGrounded = false; airMaxY = p.y;
  } else if (rocketDist() < 6) {
    piloting = true; flying = false; vmHand.visible = false;
  }
}
function updateRocket(dt) {
  arrowLook(dt);
  const look = new THREE.Vector3(); camera.getWorldDirection(look);
  const right = new THREE.Vector3().crossVectors(look, camera.up).normalize();
  const v = new THREE.Vector3(); let thrust = false;
  if (keys['KeyW']) { v.add(look); thrust = true; }
  if (keys['KeyS']) v.sub(look);
  if (keys['KeyD']) v.add(right);
  if (keys['KeyA']) v.sub(right);
  if (keys['Space']) { v.y += 1; thrust = true; }
  if (keys['ShiftLeft'] || keys['ShiftRight']) v.y -= 1;
  if (v.lengthSq() > 0) v.normalize().multiplyScalar(ROCKET_SPEED * dt);
  rocket.position.add(v);
  if (rocket.position.y < 2) rocket.position.y = 2;
  rocket.rotation.z = -v.x * 1.5; rocket.rotation.x = v.z * 1.5;  // lean into motion
  flame.visible = thrust;
  flame.scale.y = 0.7 + Math.random() * 0.7;
  const horiz = look.clone(); horiz.y = 0;
  if (horiz.lengthSq() < 0.01) horiz.set(0, 0, -1);
  horiz.normalize();
  const cam = controls.getObject().position;
  cam.copy(rocket.position).addScaledVector(horiz, -7); cam.y += 3.5;
}

// ============================================================ mobs
const MOB_R = 0.4, MOB_H = 1.0, MOB_JUMP = 7, MOB_MAX = 64;
const PASSIVE_KINDS = [
  { name: 'Pig',     body: 0xe79aa6, head: 0xe0858f, leg: 0x5a4030, hp: 10, speed: 2.0, shape: 'quad' },
  { name: 'Cow',     body: 0x5e4632, head: 0xeeeae0, leg: 0x3a2c20, hp: 12, speed: 1.8, shape: 'quad' },
  { name: 'Sheep',   body: 0xeeeee6, head: 0xe6d6c2, leg: 0xcabfae, hp: 10, speed: 2.0, shape: 'quad' },
  { name: 'Chicken', body: 0xf4f4ee, head: 0xf2c84b, leg: 0xf2a23a, hp: 6,  speed: 2.4, shape: 'quad' },
  { name: 'Rabbit',  body: 0xc8a37a, head: 0xd8b48c, leg: 0x9a7350, hp: 5,  speed: 3.0, shape: 'quad' },
  { name: 'Iguana',  body: 0x6fae4a, head: 0x7cbb55, leg: 0x4f7d34, hp: 6,  speed: 1.6, shape: 'iguana' },
  { name: 'Ostrich', body: 0x4a4038, head: 0xe8c6a0, leg: 0xd9b48c, hp: 10, speed: 3.2, shape: 'ostrich' },
  { name: 'Cheetah', body: 0xd9a441, head: 0xe0b057, leg: 0xc28b30, hp: 10, speed: 4.4, shape: 'cheetah' },
];
const HOSTILE_KINDS = [
  { name: 'Zombie',  body: 0x3f7a3a, head: 0x6b8f5a, leg: 0x33485a, hp: 16, speed: 2.4, dmg: 3, detect: 18, shape: 'biped',   hostile: true, weight: 1 },
  { name: 'Spider',  body: 0x2a2230, head: 0x442b3a, leg: 0x1c1620, hp: 12, speed: 3.4, dmg: 2, detect: 15, shape: 'spider',  hostile: true, weight: 1 },
  { name: 'Creeper', body: 0x4e9a3a, head: 0x57a341, leg: 0x2f5f25, hp: 14, speed: 2.6, dmg: 0, detect: 16, shape: 'creeper', hostile: true, weight: 0.9, explode: true },
  { name: 'Hydra',   body: 0x2f7d5a, head: 0x3fa06f, leg: 0x224d3a, hp: 60, speed: 1.5, dmg: 6, detect: 24, shape: 'hydra',   hostile: true, weight: 0.15 },
  { name: 'Dragon',  body: 0x6a3550, head: 0x7d4a66, leg: 0x4a2438, hp: 90, speed: 7.0, dmg: 7, detect: 44, shape: 'dragon',  hostile: true, weight: 0.2, fly: true },
  { name: 'Alien',   body: 0x57c08a, head: 0x8df0bd, leg: 0x2f7d5a, hp: 14, speed: 2.8, dmg: 4, detect: 18, shape: 'alien',   hostile: true, weight: 0.7 },
];
const BIRD_KIND = { name: 'Bird', body: 0x4a86e0, head: 0x3f73c4, leg: 0xf2a23a, hp: 4, speed: 9, shape: 'bird', fly: true };
const mobs = [];
const mobGroups = [];

function box(w, h, d, color, x, y, z) {
  const m = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), new THREE.MeshLambertMaterial({ color }));
  m.position.set(x, y, z);
  return m;
}
function buildBody(k) {
  const g = new THREE.Group(); let parts;
  if (k.shape === 'biped') {
    parts = [
      box(0.6, 0.9, 0.35, k.body, 0, 0.95, 0),
      box(0.5, 0.5, 0.5, k.head, 0, 1.65, 0),
      box(0.22, 0.7, 0.22, k.body, 0.4, 0.95, 0),   // arms
      box(0.22, 0.7, 0.22, k.body, -0.4, 0.95, 0),
      box(0.24, 0.55, 0.24, k.leg, 0.16, 0.28, 0),  // legs
      box(0.24, 0.55, 0.24, k.leg, -0.16, 0.28, 0),
    ];
  } else if (k.shape === 'spider') {
    parts = [
      box(0.9, 0.45, 1.1, k.body, 0, 0.45, 0),
      box(0.5, 0.4, 0.5, k.head, 0, 0.45, 0.7),
      box(0.9, 0.12, 0.12, k.leg, 0.7, 0.45, 0.2),
      box(0.9, 0.12, 0.12, k.leg, -0.7, 0.45, 0.2),
      box(0.9, 0.12, 0.12, k.leg, 0.7, 0.45, -0.2),
      box(0.9, 0.12, 0.12, k.leg, -0.7, 0.45, -0.2),
    ];
  } else if (k.shape === 'creeper') {
    parts = [
      box(0.55, 1.1, 0.35, k.body, 0, 0.95, 0),         // tall body
      box(0.5, 0.5, 0.5, k.head, 0, 1.65, 0),            // head
      box(0.24, 0.42, 0.3, k.leg, 0.16, 0.21, 0.28),     // 4 stubby feet
      box(0.24, 0.42, 0.3, k.leg, -0.16, 0.21, 0.28),
      box(0.24, 0.42, 0.3, k.leg, 0.16, 0.21, -0.28),
      box(0.24, 0.42, 0.3, k.leg, -0.16, 0.21, -0.28),
    ];
  } else if (k.shape === 'hydra') {
    parts = [
      box(1.5, 1.3, 2.4, k.body, 0, 1.05, 0),            // bulky body
      box(0.45, 0.55, 0.45, k.leg, 0.55, 0.32, 0.8),     // 4 thick legs
      box(0.45, 0.55, 0.45, k.leg, -0.55, 0.32, 0.8),
      box(0.45, 0.55, 0.45, k.leg, 0.55, 0.32, -0.8),
      box(0.45, 0.55, 0.45, k.leg, -0.55, 0.32, -0.8),
      box(0.5, 0.4, 1.2, k.body, 0, 1.2, -1.5),          // tail
    ];
    for (const [nx, lean] of [[0, 0], [0.55, 0.18], [-0.55, -0.18]]) { // 3 necks + heads
      parts.push(box(0.32, 1.1, 0.32, k.body, nx, 2.0, 1.0 + lean));
      parts.push(box(0.6, 0.55, 0.8, k.head, nx, 2.65, 1.35 + lean));
    }
  } else if (k.shape === 'dragon') {
    parts = [
      box(1.2, 1.0, 2.6, k.body, 0, 0, 0),                // body
      box(0.45, 0.5, 1.7, k.body, 0, 0.15, -2.0),         // tail
      box(0.42, 0.5, 1.3, k.body, 0, 0.45, 1.45),         // neck
      box(0.75, 0.6, 0.95, k.head, 0, 0.75, 2.35),        // head
      box(0.16, 0.4, 0.16, k.head, 0.24, 1.1, 2.5),       // horns
      box(0.16, 0.4, 0.16, k.head, -0.24, 1.1, 2.5),
      box(0.32, 0.5, 0.32, k.leg, 0.55, -0.7, 0.5),       // legs
      box(0.32, 0.5, 0.32, k.leg, -0.55, -0.7, 0.5),
      box(0.32, 0.5, 0.32, k.leg, 0.55, -0.7, -0.7),
      box(0.32, 0.5, 0.32, k.leg, -0.55, -0.7, -0.7),
    ];
    const wingL = box(2.6, 0.1, 1.5, k.head, 1.7, 0.45, 0);   // bat wings
    const wingR = box(2.6, 0.1, 1.5, k.head, -1.7, 0.45, 0);
    wingL.userData.wing = 1; wingR.userData.wing = -1;
    parts.push(wingL, wingR);
  } else if (k.shape === 'iguana') {
    parts = [
      box(0.35, 0.3, 1.0, k.body, 0, 0.3, 0),         // long low body
      box(0.3, 0.28, 0.35, k.head, 0, 0.32, 0.62),     // head
      box(0.06, 0.18, 0.7, k.head, 0, 0.5, 0),         // dorsal crest
      box(0.16, 0.14, 0.95, k.body, 0, 0.28, -0.9),    // long tail
      box(0.5, 0.12, 0.14, k.leg, 0.3, 0.18, 0.3),     // 4 sprawled legs
      box(0.5, 0.12, 0.14, k.leg, -0.3, 0.18, 0.3),
      box(0.5, 0.12, 0.14, k.leg, 0.3, 0.18, -0.3),
      box(0.5, 0.12, 0.14, k.leg, -0.3, 0.18, -0.3),
    ];
  } else if (k.shape === 'ostrich') {
    parts = [
      box(0.7, 0.7, 0.9, k.body, 0, 1.1, 0),           // round body
      box(0.5, 0.35, 0.2, k.body, 0, 1.15, -0.55),     // tail feathers
      box(0.18, 0.9, 0.18, k.leg, 0.18, 0.45, 0.05),   // long legs
      box(0.18, 0.9, 0.18, k.leg, -0.18, 0.45, 0.05),
      box(0.16, 0.85, 0.16, k.body, 0, 1.7, 0.3),      // long neck
      box(0.28, 0.3, 0.42, k.head, 0, 2.18, 0.42),     // head
    ];
  } else if (k.shape === 'cheetah') {
    parts = [
      box(0.5, 0.5, 1.5, k.body, 0, 0.65, 0),          // sleek long body
      box(0.42, 0.42, 0.45, k.head, 0, 0.78, 0.9),     // head
      box(0.12, 0.1, 1.0, k.leg, 0, 0.58, -1.15),      // long tail
      box(0.18, 0.55, 0.18, k.leg, 0.2, 0.28, 0.5),    // 4 legs
      box(0.18, 0.55, 0.18, k.leg, -0.2, 0.28, 0.5),
      box(0.18, 0.55, 0.18, k.leg, 0.2, 0.28, -0.5),
      box(0.18, 0.55, 0.18, k.leg, -0.2, 0.28, -0.5),
    ];
  } else if (k.shape === 'alien') {
    parts = [
      box(0.5, 0.85, 0.3, k.body, 0, 0.9, 0),            // slender body
      box(0.72, 0.7, 0.72, k.head, 0, 1.7, 0),           // big head
      box(0.62, 0.16, 0.16, 0x101820, 0, 1.74, 0.36),    // dark eye band
      box(0.18, 0.6, 0.18, k.body, 0.32, 0.9, 0),        // thin arms
      box(0.18, 0.6, 0.18, k.body, -0.32, 0.9, 0),
      box(0.2, 0.55, 0.2, k.leg, 0.14, 0.28, 0),
      box(0.2, 0.55, 0.2, k.leg, -0.14, 0.28, 0),
      box(0.06, 0.3, 0.06, k.head, 0.18, 2.18, 0),       // antennae
      box(0.06, 0.3, 0.06, k.head, -0.18, 2.18, 0),
    ];
  } else if (k.shape === 'bird') {
    parts = [
      box(0.42, 0.42, 0.85, k.body, 0, 0, 0),            // body
      box(0.32, 0.32, 0.32, k.head, 0, 0.16, 0.52),      // head
      box(0.12, 0.1, 0.22, k.leg, 0, 0.13, 0.76),        // beak
      box(0.46, 0.5, 0.5, k.body, 0, -0.04, -0.5),       // tail
    ];
    const wL = box(0.95, 0.08, 0.5, k.body, 0.6, 0.05, 0);
    const wR = box(0.95, 0.08, 0.5, k.body, -0.6, 0.05, 0);
    wL.userData.wing = 1; wR.userData.wing = -1;
    parts.push(wL, wR);
  } else { // quad
    parts = [
      box(0.85, 0.6, 1.25, k.body, 0, 0.7, 0),
      box(0.6, 0.6, 0.6, k.head, 0, 0.85, 0.85),
      box(0.22, 0.5, 0.22, k.leg, 0.28, 0.25, 0.45),
      box(0.22, 0.5, 0.22, k.leg, -0.28, 0.25, 0.45),
      box(0.22, 0.5, 0.22, k.leg, 0.28, 0.25, -0.45),
      box(0.22, 0.5, 0.22, k.leg, -0.28, 0.25, -0.45),
    ];
  }
  parts.forEach(p => g.add(p));
  return { g, parts };
}
function spawnFrom(kind, x, z) {
  const { g, parts } = buildBody(kind);
  g.position.set(x + 0.5, surfaceY(Math.floor(x), Math.floor(z)) + 0.2, z + 0.5);
  scene.add(g);
  const mob = { group: g, parts, kind, hp: kind.hp, speed: kind.speed, hostile: !!kind.hostile,
                vy: 0, onGround: false, blocked: false, heading: Math.random() * TAU,
                moving: true, wander: 1 + Math.random() * 3, hitT: 0, attackCD: 0, fuse: 0, bob: Math.random() * TAU,
                home: { x: 0, z: 0 }, leash: SIZE - 1 };   // roam-leash (overridden for planet mobs)
  g.userData.mob = mob;
  mobs.push(mob); mobGroups.push(g);
  return mob;
}
// spawn at an explicit position (e.g. a planet platform) with a local leash
function spawnFromAt(kind, x, y, z, home, leash) {
  const m = spawnFrom(kind, x, z);
  m.group.position.set(x + 0.5, y, z + 0.5);
  if (home) m.home = home;
  if (leash != null) m.leash = leash;
  return m;
}
function spawnPassive(x, z) { return spawnFrom(PASSIVE_KINDS[Math.floor(Math.random() * PASSIVE_KINDS.length)], x, z); }
function spawnHostile(x, z) {
  let total = 0; for (const k of HOSTILE_KINDS) total += (k.weight ?? 1);
  let r = Math.random() * total, pick = HOSTILE_KINDS[0];
  for (const k of HOSTILE_KINDS) { r -= (k.weight ?? 1); if (r <= 0) { pick = k; break; } }
  return spawnFrom(pick, x, z);
}
function setEmissive(mob, hex) { mob.parts.forEach(p => p.material.emissive.setHex(hex)); }
function removeMob(mob) {
  scene.remove(mob.group);
  mobs.splice(mobs.indexOf(mob), 1);
  mobGroups.splice(mobGroups.indexOf(mob.group), 1);
}
// ---- dragon fireballs ----
const fireballs = [];
function dragonBreathe(mob) {
  const head = mob.group.position;
  const pp = controls.getObject().position;
  const dir = new THREE.Vector3(pp.x - head.x, (pp.y - 0.6) - head.y, pp.z - head.z).normalize();
  const m = new THREE.Mesh(new THREE.SphereGeometry(0.38, 8, 8), new THREE.MeshBasicMaterial({ color: 0xff6a1a }));
  m.position.copy(head).addScaledVector(dir, 2.6);
  scene.add(m);
  fireballs.push({ m, vel: dir.multiplyScalar(26), life: 3 });
  spawnParticles(head.x - 0.5, head.y, head.z - 0.5, 0xff8a2a, 5);
}
function updateFireballs(dt) {
  for (let i = fireballs.length - 1; i >= 0; i--) {
    const f = fireballs[i];
    f.m.position.addScaledVector(f.vel, dt);
    const p = f.m.position, pp = controls.getObject().position;
    let hit = false;
    if (Math.hypot(p.x - pp.x, p.y - (pp.y - 0.8), p.z - pp.z) < 1.2) { hurtByMob(6, p); hit = true; }
    else if (isSolid(world.get(key(Math.floor(p.x), Math.floor(p.y), Math.floor(p.z))))) hit = true;
    if (hit) { spawnParticles(p.x - 0.5, p.y, p.z - 0.5, 0xff7a1a, 10); scene.remove(f.m); fireballs.splice(i, 1); continue; }
    f.life -= dt;
    if (f.life <= 0 || p.y < -30) { scene.remove(f.m); fireballs.splice(i, 1); }
  }
}
// ---- flying mobs (dragon): free 3D flight, swoop the player, breathe fire ----
function updateFlyer(mob, dt) {
  const g = mob.group, k = mob.kind;
  const pp = controls.getObject().position;
  const dxz = Math.hypot(pp.x - g.position.x, pp.z - g.position.z);
  const chase = mob.hostile && gameMode === 'survival' && !dead && dxz < k.detect;
  let tx, ty, tz;
  if (chase) {
    tx = pp.x; tz = pp.z; ty = pp.y + 4 + Math.sin(clock * 0.8 + mob.bob) * 3;
  } else {
    mob.wander -= dt;
    if (mob.wander <= 0) { mob.heading = Math.random() * TAU; mob.wander = 3 + Math.random() * 4; }
    tx = g.position.x + Math.cos(mob.heading) * 8;
    tz = g.position.z + Math.sin(mob.heading) * 8;
    ty = surfaceY(Math.floor(g.position.x), Math.floor(g.position.z)) + 14 + Math.sin(clock + mob.bob) * 2;
  }
  const mx = tx - g.position.x, my = ty - g.position.y, mz = tz - g.position.z;
  const len = Math.hypot(mx, my, mz) || 1;
  const step = Math.min(len, k.speed * dt);
  g.position.x += mx / len * step; g.position.y += my / len * step; g.position.z += mz / len * step;
  const fod = Math.hypot(g.position.x - mob.home.x, g.position.z - mob.home.z);
  if (fod > mob.leash) {
    const a = Math.atan2(g.position.z - mob.home.z, g.position.x - mob.home.x);
    g.position.x = mob.home.x + Math.cos(a) * mob.leash;
    g.position.z = mob.home.z + Math.sin(a) * mob.leash;
  }
  const heading = Math.atan2(mz, mx);
  g.rotation.y = -heading + Math.PI / 2;
  const flap = Math.sin(clock * 6 + mob.bob) * 0.5;
  for (const p of mob.parts) if (p.userData.wing) p.rotation.z = p.userData.wing * flap;
  if (chase) {
    mob.attackCD -= dt;
    const d3 = Math.hypot(pp.x - g.position.x, (pp.y - 0.6) - g.position.y, pp.z - g.position.z);
    if (mob.attackCD <= 0 && d3 < 34) { dragonBreathe(mob); mob.attackCD = 1.8; }
    if (d3 < 3.2 && mob.attackCD < 1.4) { hurtByMob(k.dmg, g.position); mob.attackCD = 1.8; }
  }
  if (mob.hitT > 0) { mob.hitT -= dt; if (mob.hitT <= 0) setEmissive(mob, 0x000000); }
}
function updateMob(mob, dt) {
  if (mob.kind.fly) { updateFlyer(mob, dt); return; }
  const g = mob.group;
  let chasing = false;
  if (mob.hostile && gameMode === 'survival' && !dead) {
    const pp = controls.getObject().position;
    const dx = pp.x - g.position.x, dz = pp.z - g.position.z;
    const d = Math.hypot(dx, dz);
    if (d < mob.kind.detect) {
      chasing = true; mob.moving = true;
      mob.heading = Math.atan2(dz, dx);
      g.rotation.y = -mob.heading + Math.PI / 2;
      if (mob.kind.explode) {
        if (d < 2.4 && Math.abs((pp.y - PLAYER_H) - g.position.y) < 2.5) {
          mob.moving = false;                       // stop and prime
          mob.fuse += dt;
          setEmissive(mob, (Math.sin(mob.fuse * 28) > 0) ? 0x66ff33 : 0x000000);
          const s = 1 + Math.min(0.6, mob.fuse * 0.5);
          g.scale.set(s, s, s);
          if (mob.fuse > 1.1) { explodeCreeper(mob); return; }
        } else if (mob.fuse > 0) {                   // player escaped: defuse
          mob.fuse = Math.max(0, mob.fuse - dt * 2);
          if (mob.fuse === 0) { setEmissive(mob, 0x000000); g.scale.set(1, 1, 1); }
        }
      } else {
        mob.attackCD -= dt;
        if (d < 1.7 && Math.abs((pp.y - PLAYER_H) - g.position.y) < 2 && mob.attackCD <= 0) {
          hurtByMob(mob.kind.dmg, g.position); mob.attackCD = 0.8;
        }
      }
    }
  }
  if (!chasing) {
    mob.wander -= dt;
    if (mob.wander <= 0) { mob.heading = Math.random() * TAU; mob.moving = Math.random() < 0.75; mob.wander = 2 + Math.random() * 4; }
    if (mob.moving) g.rotation.y = -mob.heading + Math.PI / 2;
  }
  const spd = mob.speed * dt;
  let dxm = 0, dzm = 0;
  if (mob.moving) { dxm = Math.cos(mob.heading) * spd; dzm = Math.sin(mob.heading) * spd; }

  g.position.x += dxm;
  if (collideBox(g.position.x, g.position.y, g.position.z, MOB_R, MOB_H)) { g.position.x -= dxm; mob.blocked = true; }
  g.position.z += dzm;
  if (collideBox(g.position.x, g.position.y, g.position.z, MOB_R, MOB_H)) { g.position.z -= dzm; mob.blocked = true; }

  mob.vy -= GRAVITY * dt;
  g.position.y += mob.vy * dt;
  if (collideBox(g.position.x, g.position.y, g.position.z, MOB_R, MOB_H)) {
    g.position.y -= mob.vy * dt;
    if (mob.vy < 0) mob.onGround = true;
    mob.vy = 0;
  } else mob.onGround = false;
  if (mob.blocked && mob.onGround) mob.vy = MOB_JUMP;
  mob.blocked = false;

  const od = Math.hypot(g.position.x - mob.home.x, g.position.z - mob.home.z);
  if (od > mob.leash) {
    mob.heading += Math.PI;
    const a = Math.atan2(g.position.z - mob.home.z, g.position.x - mob.home.x);
    g.position.x = mob.home.x + Math.cos(a) * mob.leash;
    g.position.z = mob.home.z + Math.sin(a) * mob.leash;
  }
  if (mob.hitT > 0) { mob.hitT -= dt; if (mob.hitT <= 0) setEmissive(mob, 0x000000); }
  if (g.position.y < -30) removeMob(mob);
}
function hurtMob(mob, dmg, dir) {
  mob.hp -= dmg;
  mob.hitT = 0.18; setEmissive(mob, 0x888888);
  mob.vy = 5;
  mob.group.position.x += dir.x * 0.6;
  mob.group.position.z += dir.z * 0.6;
  if (mob.hp <= 0) {
    spawnParticles(mob.group.position.x - 0.5, mob.group.position.y, mob.group.position.z - 0.5, mob.kind.body, 14);
    removeMob(mob);
  }
}
function explodeCreeper(mob) {
  const g = mob.group;
  const ex = g.position.x, ey = g.position.y, ez = g.position.z;
  // blast damage to player, falling off with distance
  const pp = controls.getObject().position;
  const pd = Math.hypot(pp.x - ex, (pp.y - PLAYER_H) - ey, pp.z - ez);
  if (pd < 4.5) hurtByMob(Math.max(1, Math.round((1 - pd / 4.5) * 18)), g.position);
  // also harm nearby mobs
  for (const m of mobs.slice()) {
    if (m === mob) continue;
    const md = Math.hypot(m.group.position.x - ex, m.group.position.y - ey, m.group.position.z - ez);
    if (md < 4) hurtMob(m, 14, { x: (m.group.position.x - ex) / (md || 1), z: (m.group.position.z - ez) / (md || 1) });
  }
  // carve a crater
  const R = 3, bx = Math.floor(ex), by = Math.floor(ey), bz = Math.floor(ez);
  for (let dx = -R; dx <= R; dx++) for (let dy = -R; dy <= R; dy++) for (let dz = -R; dz <= R; dz++) {
    if (dx * dx + dy * dy + dz * dz > R * R) continue;
    const k = key(bx + dx, by + dy, bz + dz), t = world.get(k);
    if (t && t !== 'bedrock') { world.delete(k); refreshAround(bx + dx, by + dy, bz + dz); }
  }
  spawnParticles(ex - 1, ey, ez - 1, 0x333333, 40);
  spawnParticles(ex - 0.5, ey + 0.5, ez - 0.5, mob.kind.body, 18);
  if (pd < 4.5) hurtFlash = Math.max(hurtFlash, 0.6);
  removeMob(mob);
}
function passiveCount() { let n = 0; for (const m of mobs) if (!m.hostile && !m.kind.fly) n++; return n; }
function hostileCount() { return mobs.length - passiveCount(); }
function randomSurface(range) {
  const x = Math.floor((Math.random() - 0.5) * range);
  const z = Math.floor((Math.random() - 0.5) * range);
  return heightAt(x, z) > SEA ? { x, z } : null;
}
for (let i = 0; i < 16; i++) { const s = randomSurface(60); if (s) spawnPassive(s.x, s.z); }
// birds flying over the home world
for (let i = 0; i < 7; i++) {
  const s = randomSurface(60);
  if (s) { const b = spawnFrom(BIRD_KIND, s.x, s.z); b.group.position.y = surfaceY(s.x, s.z) + 12 + Math.random() * 6; }
}
// aliens waiting on each planet's landing platform
const ALIEN_KIND = HOSTILE_KINDS.find(k => k.name === 'Alien');
for (const pl of PLANETS) {
  for (let i = 0; i < pl.aliens; i++) {
    const ang = Math.random() * TAU, rr = Math.random() * (pl.platR - 2);
    const ax = Math.floor(pl.px + Math.cos(ang) * rr), az = Math.floor(pl.pz + Math.sin(ang) * rr);
    spawnFromAt(ALIEN_KIND, ax, pl.platY + 1, az, { x: pl.px, z: pl.pz }, pl.platR - 1);
  }
}
let spawnTimer = 4;

// ============================================================ break / place / attack
const raycaster = new THREE.Raycaster();
const center = new THREE.Vector2(0, 0);

addEventListener('contextmenu', (e) => e.preventDefault());
addEventListener('mousedown', (e) => {
  if (!controls.isLocked || dead || piloting) return;
  swing();
  if (e.button === 0) leftClick();
  else if (e.button === 2) rightClick();
});
addEventListener('wheel', (e) => { if (controls.isLocked) selectSlot((currentSlot + (e.deltaY > 0 ? 1 : 8)) % 9); });

function nearestMob() {
  raycaster.far = 5;
  raycaster.setFromCamera(center, camera);
  const hits = raycaster.intersectObjects(mobGroups, true);
  if (!hits.length) return null;
  let o = hits[0].object;
  while (o && !o.userData.mob) o = o.parent;
  return o ? { mob: o.userData.mob, dist: hits[0].distance } : null;
}
// ============================================================ arrows (bow)
const arrows = [];
const ARROW_SPEED = 34, ARROW_GRAVITY = GRAVITY * 0.35;
function makeArrow() {
  const g = new THREE.Group();
  g.add(box(0.04, 0.04, 0.6, 0x8a5a2b, 0, 0, 0));        // shaft (+z)
  g.add(box(0.09, 0.09, 0.14, 0xcfd6dd, 0, 0, 0.34));    // tip
  g.add(box(0.14, 0.02, 0.12, 0xeeeeee, 0, 0, -0.28));   // fletching
  g.add(box(0.02, 0.14, 0.12, 0xeeeeee, 0, 0, -0.28));
  return g;
}
const ARROW_FWD = new THREE.Vector3(0, 0, 1);
function shootArrow() {
  const dir = new THREE.Vector3();
  camera.getWorldDirection(dir);
  const g = makeArrow();
  const start = controls.getObject().position.clone().addScaledVector(dir, 0.6);
  g.position.copy(start);
  scene.add(g);
  arrows.push({ g, vel: dir.clone().multiplyScalar(ARROW_SPEED), life: 4 });
}
function removeArrow(i) { scene.remove(arrows[i].g); arrows.splice(i, 1); }
function updateArrows(dt) {
  for (let i = arrows.length - 1; i >= 0; i--) {
    const a = arrows[i];
    a.vel.y -= ARROW_GRAVITY * dt;
    a.g.position.addScaledVector(a.vel, dt);
    a.g.quaternion.setFromUnitVectors(ARROW_FWD, a.vel.clone().normalize());
    const p = a.g.position;
    // mob hit
    let hit = false;
    for (const m of mobs) {
      const mp = m.group.position;
      if (Math.hypot(p.x - mp.x, p.y - (mp.y + 0.5), p.z - mp.z) < 0.8) {
        const d = a.vel.clone(); d.y = 0; d.normalize();
        hurtMob(m, 5, d); hit = true; break;
      }
    }
    if (hit) { removeArrow(i); continue; }
    // block hit
    if (isSolid(world.get(key(Math.floor(p.x), Math.floor(p.y), Math.floor(p.z))))) {
      spawnParticles(Math.floor(p.x), Math.floor(p.y), Math.floor(p.z), 0x8a5a2b, 3);
      removeArrow(i); continue;
    }
    a.life -= dt;
    if (a.life <= 0 || p.y < -30) removeArrow(i);
  }
}

// ============================================================ bullets (gun)
const bullets = [];
const BULLET_SPEED = 80;
function shootBullet() {
  const dir = new THREE.Vector3();
  camera.getWorldDirection(dir);
  const start = controls.getObject().position.clone().addScaledVector(dir, 0.6);
  const m = new THREE.Mesh(new THREE.SphereGeometry(0.06, 6, 6), new THREE.MeshBasicMaterial({ color: 0xffe066 }));
  m.position.copy(start);
  scene.add(m);
  bullets.push({ m, vel: dir.clone().multiplyScalar(BULLET_SPEED), life: 2 });
  spawnParticles(start.x - 0.5, start.y - 0.5, start.z - 0.5, 0xffd24a, 2);
}
function updateBullets(dt) {
  for (let i = bullets.length - 1; i >= 0; i--) {
    const b = bullets[i];
    let hit = false;
    for (let s = 0; s < 4 && !hit; s++) {
      b.m.position.addScaledVector(b.vel, dt / 4);
      const p = b.m.position;
      for (const m of mobs) {
        const mp = m.group.position;
        if (Math.hypot(p.x - mp.x, p.y - (mp.y + 0.5), p.z - mp.z) < 1.2) {
          const d = b.vel.clone(); d.y = 0; d.normalize();
          hurtMob(m, 8, d); hit = true; break;
        }
      }
      if (!hit && isSolid(world.get(key(Math.floor(p.x), Math.floor(p.y), Math.floor(p.z))))) {
        spawnParticles(Math.floor(p.x), Math.floor(p.y), Math.floor(p.z), 0xffffff, 3); hit = true;
      }
    }
    b.life -= dt;
    if (hit || b.life <= 0 || b.m.position.y < -30) { scene.remove(b.m); bullets.splice(i, 1); }
  }
}
function leftClick() {
  const held = hotbar[currentSlot];
  if (held === 'bow') { shootArrow(); return; }
  if (held === 'gun') { shootBullet(); return; }
  const mobHit = nearestMob();
  const blockDist = aimBlock ? distToBlock(aimBlock) : Infinity;
  if (mobHit && mobHit.dist <= blockDist) {
    const dir = new THREE.Vector3(); camera.getWorldDirection(dir); dir.y = 0; dir.normalize();
    hurtMob(mobHit.mob, held === 'sword' ? 5 : 2, dir);
    return;
  }
  if (!aimBlock) return;
  const { x, y, z } = aimBlock;
  if (world.get(key(x, y, z)) === 'bedrock') return;
  const broken = world.get(key(x, y, z));
  world.delete(key(x, y, z));
  refreshAround(x, y, z);
  spawnParticles(x, y, z, BLOCKS[broken].color, 10);
}
function rightClick() {
  const held = hotbar[currentSlot];
  if (!aimBlock || !isBlock(held)) return;
  const nx = aimBlock.x + aimBlock.nx, ny = aimBlock.y + aimBlock.ny, nz = aimBlock.z + aimBlock.nz;
  if (world.has(key(nx, ny, nz))) return;
  const p = controls.getObject().position, feet = Math.floor(p.y - PLAYER_H);
  if (Math.floor(p.x) === nx && Math.floor(p.z) === nz && (ny === feet || ny === feet + 1)) return;
  world.set(key(nx, ny, nz), held);
  refreshAround(nx, ny, nz);
  pops.push({ type: held, x: nx, y: ny, z: nz, t: 0 });
}
function distToBlock(b) {
  const p = controls.getObject().position;
  return Math.hypot(b.x + 0.5 - p.x, b.y + 0.5 - p.y, b.z + 0.5 - p.z);
}
function updatePops(dt) {
  for (let i = pops.length - 1; i >= 0; i--) {
    const a = pops[i];
    a.t += dt;
    const r = rendered.get(key(a.x, a.y, a.z));
    if (!r || r[0] !== a.type) { pops.splice(i, 1); continue; }
    const bm = meshes[a.type];
    const p = Math.min(1, a.t / 0.12);
    bm.mesh.setMatrixAt(r[1], instMatrix(a.x, a.y, a.z, 0.2 + 0.8 * p));
    bm.mesh.instanceMatrix.needsUpdate = true;
    if (p >= 1) pops.splice(i, 1);
  }
}

// ============================================================ held-item viewmodel
const vmScene = new THREE.Scene();
const vmCamera = new THREE.PerspectiveCamera(50, innerWidth / innerHeight, 0.01, 10);
vmScene.add(new THREE.HemisphereLight(0xffffff, 0x444444, 1.1));
const vmLight = new THREE.DirectionalLight(0xffffff, 0.6); vmLight.position.set(1, 2, 2); vmScene.add(vmLight);
const vmHand = new THREE.Group();
vmHand.position.set(0.62, -0.5, -1.1);
vmScene.add(vmHand);
let swingT = 0;
const SWING_DUR = 0.22;
function swing() { swingT = SWING_DUR; }
function buildHeld(itemId) {
  vmHand.clear();
  if (itemId === 'sword') {
    const blade = box(0.07, 0.7, 0.07, 0xc9d2da, 0, 0.25, 0);
    const guard = box(0.32, 0.08, 0.08, 0x6b4a2b, 0, -0.12, 0);
    const handle = box(0.08, 0.26, 0.08, 0x4a3320, 0, -0.3, 0);
    const g = new THREE.Group(); g.add(blade, guard, handle);
    g.rotation.set(0.2, 0.5, 0.5); g.scale.set(0.9, 0.9, 0.9);
    vmHand.add(g);
  } else if (itemId === 'bow') {
    const wood = 0x7a5024;
    const upper = box(0.05, 0.42, 0.05, wood, 0, 0.2, 0);  upper.rotation.z = 0.38;
    const lower = box(0.05, 0.42, 0.05, wood, 0, -0.2, 0); lower.rotation.z = -0.38;
    const grip  = box(0.06, 0.2, 0.06, 0x5a3a1c, 0, 0, 0);
    const string = box(0.012, 0.78, 0.012, 0xe8e2d0, -0.13, 0, 0);
    const g = new THREE.Group(); g.add(upper, lower, grip, string);
    g.rotation.set(0.1, 0.5, 0.15);
    vmHand.add(g);
  } else if (itemId === 'gun') {
    const g = new THREE.Group();
    g.add(box(0.13, 0.15, 0.55, 0x33373c, 0, 0.04, -0.05));   // receiver
    g.add(box(0.08, 0.08, 0.55, 0x202327, 0, 0.09, -0.42));   // barrel
    g.add(box(0.15, 0.27, 0.16, 0x44484e, 0, -0.2, 0.14));    // grip
    g.add(box(0.1, 0.2, 0.14, 0x202327, 0, -0.05, 0.2));      // magazine
    g.rotation.set(0.04, 0.42, 0);
    vmHand.add(g);
  } else {
    const c = box(0.5, 0.5, 0.5, BLOCKS[itemId].color, 0, 0, 0);
    c.rotation.set(0.4, 0.7, 0);
    vmHand.add(c);
  }
}
function updateViewmodel(dt) {
  if (swingT > 0) {
    swingT -= dt;
    const a = Math.sin((1 - swingT / SWING_DUR) * Math.PI);
    vmHand.rotation.set(-a * 0.9, 0, 0);
    vmHand.position.z = -1.1 + a * 0.25;
  } else { vmHand.rotation.set(0, 0, 0); vmHand.position.z = -1.1; }
}

// ============================================================ hotbar + creative menu
const hud = document.getElementById('hud');
const hotbar = ['sword', 'bow', 'gun', 'grass', 'dirt', 'stone', 'cobblestone', 'planks', 'glass'];
let currentSlot = 0;
const slotEls = hotbar.map(() => { const el = document.createElement('div'); el.className = 'slot'; hud.appendChild(el); return el; });
function paintSlot(i) {
  const id = hotbar[i];
  slotEls[i].style.background = swatch(id);
  slotEls[i].innerHTML = `<span class="num">${i + 1}</span>${itemName(id)}`;
}
function selectSlot(i) {
  currentSlot = i;
  slotEls.forEach((el, j) => el.classList.toggle('active', j === i));
  buildHeld(hotbar[i]);
}
hotbar.forEach((_, i) => paintSlot(i));
selectSlot(0);

const menuGrid = document.getElementById('menuGrid');
for (const id of [...Object.keys(TOOLS), ...TYPES]) {
  const tile = document.createElement('div');
  tile.className = 'tile';
  tile.style.background = swatch(id);
  tile.textContent = itemName(id);
  tile.addEventListener('click', () => { hotbar[currentSlot] = id; paintSlot(currentSlot); buildHeld(id); closeMenu(); });
  menuGrid.appendChild(tile);
}
function toggleMenu() { menuOpen ? closeMenu() : openMenu(); }
function openMenu() { menuOpen = true; menu.classList.remove('hidden'); controls.unlock(); }
function closeMenu() { menuOpen = false; menu.classList.add('hidden'); controls.lock(); }

// ============================================================ loop
let prev = performance.now(), fps = 60, infoT = 0;
function animate() {
  requestAnimationFrame(animate);
  const now = performance.now();
  const dt = Math.min((now - prev) / 1000, 0.05);
  prev = now;
  clock += dt;
  fps += ((1 / Math.max(dt, 0.0001)) - fps) * 0.1;

  // space ambience: sky darkens, stars fade in, gravity weakens with altitude
  const camY = controls.getObject().position.y;
  const sf = Math.min(1, Math.max(0, (camY - 30) / 50));
  scene.background.copy(skyDay).lerp(skySpace, sf);
  scene.fog.color.copy(scene.background);
  scene.fog.far = 140 + sf * 500;
  stars.material.opacity = sf;
  gEff = 28 - 23 * sf;

  if (piloting) {
    updateRocket(dt);
  } else if (dead) {
    deathTimer -= dt;
    if (deathTimer <= 0) respawn();
  } else if (controls.isLocked) {
    arrowLook(dt);
    const pos = controls.getObject().position;
    const fwd = new THREE.Vector3();
    camera.getWorldDirection(fwd); fwd.y = 0; fwd.normalize();
    const right = new THREE.Vector3().crossVectors(fwd, camera.up).normalize();
    const move = new THREE.Vector3();
    if (keys['KeyW']) move.add(fwd);
    if (keys['KeyS']) move.sub(fwd);
    if (keys['KeyD']) move.add(right);
    if (keys['KeyA']) move.sub(right);
    const speed = (flying ? FLY : WALK) * dt;
    if (move.lengthSq() > 0) move.normalize().multiplyScalar(speed);

    onGround = false;
    moveAxis('x', move.x, pos);
    moveAxis('z', move.z, pos);

    if (flying) {
      let vy = 0;
      if (keys['Space']) vy += 1;
      if (keys['ShiftLeft'] || keys['ShiftRight']) vy -= 1;
      moveAxis('y', vy * FLY * dt, pos);
    } else {
      if (keys['Space'] && grounded(pos)) velocity.y = JUMP;
      velocity.y -= gEff * dt;
      moveAxis('y', velocity.y * dt, pos);
      // fall-damage tracking
      const g = grounded(pos);
      if (!g) airMaxY = Math.max(airMaxY, pos.y);
      if (g && !wasGrounded) {
        const fall = airMaxY - pos.y;
        const feetBlock = world.get(key(Math.floor(pos.x), Math.floor(pos.y - PLAYER_H), Math.floor(pos.z)));
        if (gameMode === 'survival' && fall > 4 && feetBlock !== 'water') damagePlayer(Math.floor(fall - 3));
        airMaxY = pos.y;
      }
      wasGrounded = g;
    }
    if (pos.y < -30) { if (gameMode === 'survival') die(); else { pos.copy(SPAWN); velocity.set(0, 0, 0); } }
    updateAim();
  }

  for (let i = mobs.length - 1; i >= 0; i--) updateMob(mobs[i], dt);
  spawnTimer -= dt;
  if (spawnTimer <= 0) {
    spawnTimer = 4;
    if (passiveCount() < 16 && mobs.length < MOB_MAX) { const s = randomSurface(70); if (s) spawnPassive(s.x, s.z); }
    if (gameMode === 'survival' && hostileCount() < 10 && mobs.length < MOB_MAX) {
      const p = controls.getObject().position;
      const ang = Math.random() * TAU, r = 14 + Math.random() * 12;
      const x = Math.floor(p.x + Math.cos(ang) * r), z = Math.floor(p.z + Math.sin(ang) * r);
      if (Math.abs(x) < SIZE - 1 && Math.abs(z) < SIZE - 1 && heightAt(x, z) > SEA) spawnHostile(x, z);
    }
  }

  // survival regen + hurt flash fade
  if (gameMode === 'survival' && !dead && health < MAX_HP && clock - lastHurt > 5) {
    regenTimer -= dt;
    if (regenTimer <= 0) { regenTimer = 2; health = Math.min(MAX_HP, health + 1); updateHearts(); }
  }
  if (hurtFlash > 0) { hurtFlash -= dt * 1.5; hurtEl.style.opacity = Math.max(0, hurtFlash); }

  updateParticles(dt);
  updateArrows(dt);
  updateBullets(dt);
  updateFireballs(dt);
  updatePops(dt);
  updateViewmodel(dt);

  const nearRocket = !piloting && !dead && controls.isLocked && rocketDist() < 6;
  promptEl.style.display = (nearRocket || piloting) ? 'block' : 'none';
  if (piloting) promptEl.textContent = 'Piloting — WASD/Space/Shift to fly · R to exit';
  else if (nearRocket) promptEl.textContent = 'Press R to board the rocket 🚀';

  infoT += dt;
  if (infoT > 0.25) {
    infoT = 0;
    const p = controls.getObject().position;
    info.textContent =
      `${gameMode === 'survival' ? 'SURVIVAL' : 'CREATIVE'}   FPS ${fps.toFixed(0)}\n` +
      `XYZ ${p.x.toFixed(1)} ${(p.y - PLAYER_H).toFixed(1)} ${p.z.toFixed(1)}\n` +
      `Mobs ${mobs.length}` + (piloting ? '   🚀 PILOTING' : flying ? '   FLYING' : '');
  }

  if (location.search.includes('norender')) return;
  renderer.clear();
  renderer.render(scene, camera);
  renderer.clearDepth();
  renderer.render(vmScene, vmCamera);
}

addEventListener('resize', () => {
  camera.aspect = innerWidth / innerHeight; camera.updateProjectionMatrix();
  vmCamera.aspect = innerWidth / innerHeight; vmCamera.updateProjectionMatrix();
  renderer.setSize(innerWidth, innerHeight);
});

window.__test = () => {
  const out = { errors: [] };
  try {
    out.planets = PLANETS.length;
    out.planet_spheres = PLANETS.filter(p => scene.children.includes(p.mesh)).length;
    out.platform_block_types = [...new Set([...world.values()])].filter(v => ['moonrock', 'brick', 'snow', 'obsidian', 'grass'].includes(v)).length;
    out.moon_radius = PLANETS[0].r;
    const types = mobs.map(m => m.kind.name);
    out.aliens = types.filter(n => n === 'Alien').length;
    out.birds = types.filter(n => n === 'Bird').length;
    out.has_dragon_kind = HOSTILE_KINDS.some(k => k.name === 'Dragon');
    // an alien on Mars should stay near Mars, not get yanked to the main map
    const mars = PLANETS.find(p => p.name === 'Mars');
    const marsAlien = mobs.find(m => m.kind.name === 'Alien' && Math.abs(m.group.position.x - mars.px) < mars.platR + 2);
    out.mars_alien_exists = !!marsAlien;
    if (marsAlien) {
      for (let i = 0; i < 60; i++) updateMob(marsAlien, 0.05);  // 3s of wandering
      out.mars_alien_stayed = Math.hypot(marsAlien.group.position.x - mars.px, marsAlien.group.position.z - mars.pz) <= mars.platR;
    }
    // a bird should flap + stay airborne
    const bird = mobs.find(m => m.kind.name === 'Bird');
    if (bird) {
      const y0 = bird.group.position.y;
      for (let i = 0; i < 40; i++) updateMob(bird, 0.05);
      out.bird_airborne = bird.group.position.y > 5;
      out.bird_moved = Math.abs(bird.group.position.y - y0) >= 0 && (bird.group.position.x !== 0 || bird.group.position.z !== 0);
    }
  } catch (e) { out.errors.push(String(e)); }
  return out;
};
animate();
</script>
</body>
</html>
